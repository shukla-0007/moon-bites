// Moon Bites – Prisma Schema v1
// Stores users, preferences, and order history.
// Phase 2: OrderHistory populated on every /api/surprise call.
// Phase 6: userId FK will be wired once auth is added.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  createdAt    DateTime      @default(now())
  preferences  Preferences?
  orderHistory OrderHistory[]
}

model Preferences {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id])
  veg             Boolean @default(false)
  maxBudget       Int     @default(500)
  spiceLevel      Int     @default(2)   // 1=mild, 2=medium, 3=spicy
  blacklistedTags String  @default("")  // comma-separated tag strings
}

model OrderHistory {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  flow           String   // "surprise" | "mood" | "schedule"
  restaurantId   String
  restaurantName String
  dishName       String
  dishPrice      Int
  mood           String?  // populated for mood flow only
  constraints    String   // JSON-stringified UserConstraints
  placedAt       DateTime @default(now())
}
